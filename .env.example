# =============================================
# FINANCE EMAIL AGENT - Environment Variables
# =============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# OpenAI API Key - get from platform.openai.com
OPENAI_API_KEY=sk-your-openai-api-key-here

# Gmail credentials for live email sending
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Finance/Legal team email for escalation reports
FINANCE_TEAM_EMAIL=finance@yourcompany.com

# Payment link included in every email
PAYMENT_LINK=https://pay.yourcompany.com/invoice

# Your company name used in email signature
COMPANY_NAME=Your Company Name
